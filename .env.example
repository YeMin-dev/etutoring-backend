# Copy to .env and set values. .env is gitignored; do not commit secrets.
# For dev with Docker Compose, JWT_SECRET is required; others have defaults in compose.
# For prod, set all variables here or in the deployment environment.

SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=your-jwt-secret-min-32-chars

# Database (dev defaults: postgres in compose)
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/eTutoring
SPRING_DATASOURCE_USERNAME=eTutoring
SPRING_DATASOURCE_PASSWORD=eTutoring_pw

# Mail (dev defaults: mailpit in compose; prod: set Brevo or other SMTP)
SPRING_MAIL_HOST=mailpit
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_FROM=

APP_PASSWORD_RESET_BASE_URL=http://localhost:3000
